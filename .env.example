# Daemon configuration
# HIVE_PROJECT=/path/to/hive                # Project root (default: auto-detected from daemon location)
# SEND_RETURN_BIN=/path/to/send-return      # CGEvent binary for Return keystroke (default: ~/send-return)

# Dashboard configuration
# NEXT_PUBLIC_WS_URL=ws://localhost:3002     # WebSocket URL for daemon connection (default: ws://localhost:3002)

# Hook configuration (set automatically by setup-hooks.sh)
# HIVE_DAEMON_URL=http://localhost:3001      # Daemon HTTP endpoint
# HIVE_WORKER_ID=                            # Set by Claude Code per-session
# HIVE_HOOK_EVENT=                           # Set by Claude Code per-hook
# HIVE_TOKEN=                                # Auth token (default: reads from ~/.hive/token)
