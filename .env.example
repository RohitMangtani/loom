# ── Daemon configuration ──────────────────────────────────────────
# HIVE_PROJECT=/path/to/hive                # Project root (default: auto-detected from daemon location)
# SEND_RETURN_BIN=/path/to/send-return      # CGEvent binary for Return keystroke (default: ~/send-return)

# ── Dashboard configuration (apps/dashboard/.env.local) ──────────
# REQUIRED for production (Vercel deploy). Not needed for local dev.
# NEXT_PUBLIC_WS_URL=wss://your-tunnel.ngrok-free.dev  # WebSocket URL to reach the daemon
# NEXT_PUBLIC_DASHBOARD_URL=https://your-app.vercel.app # Dashboard URL (used in invite links)

# ── Hook configuration (set automatically by setup-hooks.sh) ─────
# These are injected into Claude Code sessions by the identity hook.
# You should NOT set these manually.
# HIVE_DAEMON_URL=http://localhost:3001      # Daemon HTTP endpoint
# HIVE_WORKER_ID=                            # Set by Claude Code per-session
# HIVE_HOOK_EVENT=                           # Set by Claude Code per-hook
# HIVE_TOKEN=                                # Auth token (default: reads from ~/.hive/token)

# ── Satellite configuration (set by install.sh --connect) ────────
# These are written to ~/.hive/ files, not .env. Listed here for reference.
# PRIMARY_URL=wss://your-tunnel.ngrok-free.dev  # Primary daemon WS URL
# PRIMARY_TOKEN=<64-char-hex>                   # Auth token from primary
