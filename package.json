{
  "name": "@rohitmangtani/hive",
  "version": "1.0.0",
  "description": "Multi-agent orchestration layer. Visual workflow for AI agents.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RohitMangtani/hive"
  },
  "keywords": ["ai-agents", "orchestration", "terminal", "claude", "codex", "multi-agent", "swarm"],
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "hive": "node packages/cli/bin/hive.js",
    "launch": "bash scripts/launch-hosted.sh",
    "launch:local": "bash scripts/launch-local.sh",
    "start": "bash apps/daemon/scripts/start.sh",
    "start:satellite": "npx tsx apps/daemon/src/index.ts --satellite",
    "doctor": "bash scripts/doctor.sh",
    "dev:daemon": "npm -w apps/daemon run dev",
    "dev:dashboard": "npm -w apps/dashboard run dev",
    "desktop:prepare": "npm -w apps/daemon run build && npm -w apps/dashboard run build && npm -w apps/desktop run stage",
    "desktop:smoke": "npm -w apps/desktop run smoke",
    "desktop:dev": "npm run desktop:prepare && npm -w apps/desktop run tauri:dev",
    "desktop:build": "npm run desktop:prepare && npm -w apps/desktop run tauri:build",
    "build": "turbo build",
    "deploy:dashboard": "bash scripts/deploy-vercel.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "turbo": "^2.8.12"
  }
}
