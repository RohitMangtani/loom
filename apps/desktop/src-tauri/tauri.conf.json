{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hive",
  "version": "0.1.0",
  "identifier": "com.rohitmangtani.hive.desktop",
  "build": {
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hive",
        "width": 1480,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "resources": [
      "../.generated/runtime"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
